@model List<ClientesPedidos.Models.ClienteModel>
@using System.Linq

@{
    ViewData["Title"] = "Clientes";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/clientes.css" />
}

<div class="page-container">

    <h1 class="fw-bold mb-0">Clientes</h1>

    <div class="card form-section">

        <h4>Novo Cliente</h4>

        <form asp-action="Criar" method="post">
            @Html.AntiForgeryToken()

            <label>Nome</label>
            <input type="text" name="nome" required />

            <label>Telefone</label>
            <input type="text" name="telefone" required />

            <button type="submit">Adicionar</button>
        </form>

    </div>

    <div class="card">

        <h4>Lista de Clientes</h4>

        <table>
            <thead>
                <tr>
                    
                    <th>Nome</th>
                    <th>Telefone</th>
                    <th>Ações</th>
                </tr>
            </thead>

            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var cliente in Model)
                    {
                        <tr>
                            
                            <td>@cliente.Nome</td>
                            <td>@cliente.Telefone</td>
                            <td>
                                <form asp-action="Deletar"
                                      method="post"
                                      asp-route-id="@cliente.Id">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-delete">
                                        Excluir
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="empty-message">
                            Nenhum cliente cadastrado.
                        </td>
                    </tr>
                }
            </tbody>
        </table>

    </div>

</div>