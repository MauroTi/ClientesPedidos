<div style="width: 90%; margin: 0 auto; text-align: center;">
    <h2>Dashboard de Pedidos</h2>

    <div style="display: flex; gap: 66px; justify-content: center; flex-wrap: wrap; margin-top: 20px;">
        
        <!-- Card do gráfico de linha -->
        <div class="card form-section" border-radius: 10px; padding: 20px; box-shadow: 0 2px 5px rgba(0,0,0,0.2); width: 300px;">
            <h3 style="text-align: center; margin-bottom: 15px;">Pedidos por Dia</h3>
            <canvas id="graficoLinha" style="width: 100%; height: 200px;"></canvas>
        </div>

        <!-- Card do gráfico de pizza -->
        <div class="card form-section" border-radius: 10px; padding: 20px; box-shadow: 0 2px 5px rgba(0,0,0,0.2); width: 300px;">
            <h3 style="text-align: center; margin-bottom: 15px;">Pedidos por Período</h3>
            <canvas id="graficoPizza" style="width: 100%; height: 200px;"></canvas>
        </div>

    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    async function carregarGraficoPedidos() {
    const resposta = await fetch('/Pedidos/PedidosPorDia');
    const dados = await resposta.json();

    const labels = Object.keys(dados);
    const valores = Object.values(dados);

    const ctx = document.getElementById('graficoLinha');
    new Chart(ctx, {
    type: 'line',
    data: {
    labels: labels,
    datasets: [{
    label: 'Pedidos por Dia',
    data: valores,
    borderWidth: 3,
    tension: 0.2,
    borderColor: '#36A2EB',
    backgroundColor: 'rgba(54,162,235,0.2)'
    }]
    },
    options: {
    plugins: {
    legend: { display: false }
    }
    }
    });
    }

    async function carregarGraficoPizza() {
    const resposta = await fetch('/Pedidos/PedidosResumoPeriodo');
    const dados = await resposta.json();

    const labels = Object.keys(dados);
    const valores = Object.values(dados);

    const ctx = document.getElementById('graficoPizza');
    new Chart(ctx, {
    type: 'pie',
    data: {
    labels: labels,
    datasets: [{
    data: valores,
    backgroundColor: ['#36A2EB', '#FF6384', '#FFCE56', '#4BC0C0']
    }]
    },
    options: {
    plugins: {
    legend: { position: 'bottom' }
    }
    }
    });
    }

    carregarGraficoPedidos();
    carregarGraficoPizza();
</script>