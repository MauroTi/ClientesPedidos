<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ClientesPedidos</title>

    <!-- Bootstrap (opcional, pode remover se não usar) -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- CSS GLOBAL -->
    <link rel="stylesheet" href="~/css/layout.css" />
    <link rel="stylesheet" href="~/css/components.css" />

    <!-- CSS POR PÁGINA -->

    <link rel="stylesheet" href="~/css/layout.css" />
    <link rel="stylesheet" href="~/css/components.css" />
    @RenderSection("Styles", required: false)

</head>

<body>

    <div class="admin-wrapper">

        <!-- SIDEBAR -->
        <aside class="sidebar">
            <div class="logo">
                <h1 class="logo h1">
                <a asp-controller="Home" asp-action="Index" class="logo-link">ClientesPedidos</a>
                </h1>
            </div>

            <nav>
                <a asp-controller="Clientes" asp-action="Index">Clientes</a>
                <a asp-controller="Pedidos" asp-action="Index">Pedidos</a>

                @if (!(ViewContext.RouteData.Values["controller"]?.ToString() == "Graficos" &&
                                ViewContext.RouteData.Values["action"]?.ToString() == "Index"))
                {
                    <a asp-controller="Graficos" asp-action="Index">Gráficos</a>
                }
            </nav>
        </aside>

        <!-- CONTEÚDO PRINCIPAL -->
        <main class="main-content">
            @RenderBody()
        </main>

    </div>

    <!-- Scripts -->
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>