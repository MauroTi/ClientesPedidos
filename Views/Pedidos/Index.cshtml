@model List<ClientesPedidos.Models.PedidoListViewModel>
@using System.Linq

@{
    ViewData["Title"] = "Pedidos";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/pedidos.css" />
}

<div class="page-container">

    <h1 class="page-title">Pedidos</h1>

    <div class="card form-section">

        <h4>Novo Pedido</h4>

        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <label>Cliente</label>
            <select name="ClienteId" class="form-control">
                <option value="">Selecione</option>
                @foreach (var c in (ViewBag.Clientes ?? new List<SelectListItem>()))
                {
                    <option value="@c.Value">@c.Text</option>
                }
            </select>

            <label>Descrição</label>
            <input type="text" name="Descricao" class="form-control" required />

            <label>Valor</label>
            <input type="number" step="0.01" name="Valor" class="form-control" required />

            <button type="submit">Adicionar</button>
        </form>

    </div>

    <div class="card">

        <h4>Lista de Pedidos</h4>

        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Cliente</th>
                    <th>Descrição</th>
                    <th>Valor</th>
                    <th>Data</th>
                    <th>Ações</th>
                </tr>
            </thead>

            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var pedido in Model)
                    {
                        <tr>
                            <td>@pedido.Id</td>
                            <td>@pedido.NomeCliente</td>
                            <td>@pedido.Descricao</td>
                            <td>@pedido.Valor</td>
                            <td>@pedido.DataPedido.ToString("dd/MM/yyyy")</td>
                            <td>
                                <form asp-action="Deletar"
                                      method="post"
                                      asp-route-id="@pedido.Id">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-delete">
                                        Excluir
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="empty-message">
                            Nenhum pedido cadastrado.
                        </td>
                    </tr>
                }

            </tbody>
        </table>

    </div>

</div>