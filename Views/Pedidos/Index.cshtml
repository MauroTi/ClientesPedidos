@model IEnumerable<ClientesPedidos.ViewModels.PedidoListViewModel>

@{
    ViewData["Title"] = "Pedidos";
}

<h2>Pedidos</h2>

<a asp-action="Create" class="btn btn-success">Novo Pedido</a>

<table class="table">
    <thead>
        <tr>
            <th>Cliente</th>
            <th>Descrição</th>
            <th>Valor</th>
            <th>Data</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.NomeCliente</td>
                <td>@item.Descricao</td>
                <td>@item.Valor</td>
                <td>@item.DataPedido.ToString("dd/MM/yyyy")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id">Editar</a> |
                    <form asp-action="Delete" method="post" style="display:inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@item.Id" />
                        <button type="submit" class="btn btn-link">Excluir</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>