@model ClientesPedidos.ViewModels.PedidoCreateViewModel
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Editar Pedido";
}

<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()

    <label>Cliente</label>
    <select asp-for="ClienteId"
            asp-items="@(new SelectList(Model.Clientes, "Id", "Nome"))"
            class="form-control">
        <option value="">Selecione</option>
    </select>

    <label>Descrição</label>
    <input asp-for="Descricao" class="form-control" />

    <label>Valor</label>
    <input asp-for="Valor" type="number" step="0.01" class="form-control" />

    <button type="submit">Salvar Alterações</button>
</form>